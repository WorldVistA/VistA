procedure TPtInfoPresentation.PanelClick(Sender: TObject);
var
  Panel: TPtInfoPanel;
  InputJSON, JSON: TJSONValue;
  Form: TfrmPtInfoDetails;
  UseForm, Update, SetupNeeded: Boolean;
  FocusedControl: TWinControl;
  Error, formCaption: string;
begin
  if Sender is TPtInfoPanel then
    Panel := Sender as TPtInfoPanel
  else if (Sender is TControl) and (TControl(Sender).Parent is TPtInfoPanel)
  then
    Panel := (TControl(Sender).Parent as TPtInfoPanel)
  else
    Panel := nil;
  if Disabled or (not Assigned(Panel)) or (not IsDataValid) then
    Exit;
  JSON := nil;
  try
    Update := (ActionType = actShowMessage) or (not Assigned(FDialog)) or
      (not(FDialog as TfrmPtInfoDetails).IsActive);
    if callDetailRPC and Update then
    begin
      InputJSON := DataToJSON;
      try
        JSON := CreateJSONFromPanelClick(InputJSON, Error);
        if Error <> '' then
        begin
          ShowMessage(Error);
          Exit;
        end
        else if not Assigned(JSON) then
          Exit;
      finally
        FreeAndNil(InputJSON);
      end;
    end;
    OwnerPtInfoData.OwnerPtInfoSplitViewBase.ResetToCollapse := false;
    if Assigned(OwnerPtInfoData) and
      Assigned(OwnerPtInfoData.OwnerPtInfoSplitViewBase) and
      (OwnerPtInfoData.OwnerPtInfoSplitViewBase.OpenState = osUnpinned) and
      (PopOutType = popShowEmbedded) and (ActionType <> actShowMessage) then
      begin
        OwnerPtInfoData.OwnerPtInfoSplitViewBase.OpenState := osFloating;
        OwnerPtInfoData.OwnerPtInfoSplitViewBase.ResetToCollapse := true;
      end;
    UseForm := (ActionType in [actShowDetail, actShowURL, actShowEditor]);
    if UseForm then
    begin
      Form := GetDetailsForm as TfrmPtInfoDetails;
      SetupNeeded := Update or (not Form.IsActive);
    end
    else
    begin
      Form := nil;
      SetupNeeded := True;
    end;
    Panel.BevelOuter := bvLowered;
    try
      if SetupNeeded then
        case ActionType of
          actNone:
            ;
          actShowDetail:
            PanelShowDetail(Sender, Form, JSON, Update);
          actShowURL:
            PanelShowURL(Sender, Form, JSON, Update);
          actShowMessage:
            PanelShowMessage(Sender, JSON, Update);
          actShowEditor:
            PanelShowEditor(Sender, Form, JSON, Update);
          actShowHTMLEditor:
          begin
            if displayText <> '' then formCaption := displayText
            else if name <> '' then formCaption := name
            else formCaption := 'Information Panel Input Form';
            CreateHTMLForm(JSON, formCaption);
          end;
        end;
      if UseForm then
        if PopOutType = popShowModal then
        begin
          FocusedControl := Screen.ActiveControl;
          try
            Form.ShowModal;
          finally
            if ShouldFocus(FocusedControl) then
              FocusedControl.SetFocus;
          end;
        end
        else
        begin
          if (PopOutType = popShowEmbedded) and (TextWidthByFont(Form.lblHeader.Font.Handle,Form.lblHeader.Caption) > Form.Width) then
            Form.lblHeader.Alignment := taLeftJustify;
          OwnerPtInfoData.OwnerPtInfoSplitViewBase.PanelGrid.Visible :=
            (PopOutType = popShowNonModal);
          OwnerPtInfoData.OwnerPtInfoSplitViewBase.FormGrid.Visible :=
            (PopOutType = popShowEmbedded);
          Form.Show;
          if PopOutType = popShowEmbedded then
          begin
            Form.SetFocus;
            if (ActionType = actShowEditor) and
              (OwnerPtInfoData.OwnerPtInfoSplitViewBase.OpenState = osFloating)
            then
              with OwnerPtInfoData.OwnerPtInfoSplitViewBase do
              begin
                // Fixes display issue where the editor controls may be in the wrong place
                Width := Width + 1;
                Width := Width - 1;
              end;
          end;
        end;
    finally
      Panel.BevelOuter := bvRaised;
    end;
  finally
    FreeAndNil(JSON);
  end;
end;

procedure TPtInfoPresentation.PanelShowDetail(Sender: TObject; AForm: TForm;
  JSON: TJSONValue; Update: Boolean);
var
  Details: string;
  Form: TfrmPtInfoDetails;
begin
  Form := AForm as TfrmPtInfoDetails;
  Form.SetupDetails(dtInfo);
  Details := DetailText;
  if Assigned(JSON) then
    Details := JSON.AsTypeDef<string>('results', Details);
  Form.memDetails.Lines.Text := Details;
  FormatForURLs(Form.memDetails);
  Form.memDetails.ScrollPosition := Point(0, 0);
  Form.memDetails.CaretPos := Point(0, 0);
end;

procedure TPtInfoPresentation.PanelShowEditor(Sender: TObject; AForm: TForm;
  JSON: TJSONValue; Update: Boolean);
var
  Form: TfrmPtInfoDetails;
  GridControls: TControlCollection;
  Panel: TPanel;

begin
  Form := AForm as TfrmPtInfoDetails;
  Form.SetupDetails(dtEditor);
  if Update then
  begin
    if not Assigned(JSON) then
      Exit;
    Form.fraEditGrid.createLayoutFromJSON(DataToJSON, JSON);
    Form.lblHeader.Caption := JSON.AsTypeDef<string>('editor.displayText',
      DisplayText);
    Form.lblHeader.Hint := JSON.AsTypeDef<string>('editor.description', '');
    if Form.lblHeader.Hint <> '' then
      Form.lblHeader.ShowHint := True;
    Form.SetupButtons(JSON.AsTypeDef<string>('editor.buttonTextSave', 'Save'),
      JSON.AsTypeDef<string>('editor.buttonTextCancel', 'Cancel'));
    Form.fraEditGrid.pnlButtons.Visible := not JSON.AsTypeDef<Boolean>
      ('editor.hideButtons', False);
    Form.fraEditGrid.setInitialValues;
    GridControls := Form.fraEditGrid.grdEditPanel.ControlCollection;
    for var I := 0 to GridControls.Count - 1 do
      if GridControls[I].Control is TPanel then
      begin
        Panel := GridControls[I].Control as TPanel;
        for var j := 0 to Panel.ControlCount - 1 do
          if Panel.Controls[j] is TORDateBox then
          begin
            (Panel.Controls[j] as TORDateBox).OnDateDialogOpening :=
              EditorDateBoxOpening;
            (Panel.Controls[j] as TORDateBox).OnDateDialogClosed :=
              EditorDateBoxClosed;
          end
          else if Panel.Controls[j] is TORDateCombo then
          begin
            (Panel.Controls[j] as TORDateCombo).OnDateDialogOpening :=
              EditorDateBoxOpening;
            (Panel.Controls[j] as TORDateCombo).OnDateDialogClosed :=
              EditorDateBoxClosed;
          end;
      end;
  end;
end;

procedure TPtInfoPresentation.PanelShowMessage(Sender: TObject;
  JSON: TJSONValue; Update: Boolean);
var
  Details: string;
begin
  Details := DetailText;
  if Assigned(JSON) then
    Details := JSON.AsTypeDef<string>('results', Details);
  ShowMessage(Details);
  resetFocus;
end;

procedure TPtInfoPresentation.PanelShowURL(Sender: TObject; AForm: TForm;
  JSON: TJSONValue; Update: Boolean);
var
  AURL: string;
  Form: TfrmPtInfoDetails;
begin
  Form := AForm as TfrmPtInfoDetails;
  Form.SetupDetails(dtWeb);
  AURL := URL;
  if Assigned(JSON) then
    AURL := JSON.AsTypeDef<string>('results', AURL);
  AURL := AURL.Replace('%DFN', Patient.DFN);
  AURL := AURL.Replace('%DIVISION', Piece(RPCBrokerV.User.Division, U, 1));
  if RPCBrokerV.ListenerPort > 0 then
    AURL := AURL.Replace('%PORT', RPCBrokerV.ListenerPort.ToString);
  AURL := AURL.Replace('%SRV', RPCBrokerV.Server);
  AURL := AURL.Replace('%STATION', copy(User.StationNumber, 1, 3));
  AURL := AURL.Replace('%DUZ', User.DUZ.ToString);
  Form.wbEdgeBrowser.Navigate(AURL);
end;

