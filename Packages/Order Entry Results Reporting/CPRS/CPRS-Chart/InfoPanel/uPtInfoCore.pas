procedure TPtInfoData.AdjustPanels;
const
  MinGap = 8;
var
  I, GapCount, Min, Adjust, PanelCount, BevelWidth: Integer;
  Grid: TGridPanel;
  Rows: TRowCollection;
  Gap: Double;
  ScrollBarsNeeded, ResetNeeded: Boolean;
  IsGapRow: TArray<Boolean>;
  Control: TControl;
  Row: TCellItem;
  PanelAlign: TAlign;
begin
  if not Assigned(OwnerPtInfoSplitViewBase) then
    Exit;
  Min := 0;
  GapCount := 0;
  PanelCount := 0;
  Grid := OwnerPtInfoSplitViewBase.PanelGrid;
  Rows := Grid.RowCollection;
  SetLength(IsGapRow, Rows.Count);
  for I := 0 to Rows.Count - 1 do
  begin
    Control := Grid.ControlCollection.Controls[0, I];
    IsGapRow[I] := not(Assigned(Control) and (Control is TPtInfoPanel));
    if IsGapRow[I] then
    begin
      inc(GapCount);
      inc(Min, MinGap);
    end
    else
    begin
      inc(PanelCount);
      inc(Min, FRowHeight);
    end
  end;
  if HasImages then
    Adjust := 6
  else
    Adjust := 8;
  while (Adjust > 0) and ((Min + (Adjust * PanelCount)) > Grid.Parent.Height) do
    dec(Adjust, 2);
  ScrollBarsNeeded := (Min + (Adjust * PanelCount)) > Grid.Parent.Height;
  if GapCount < 1 then
    GapCount := 1;
  Gap := 100 / GapCount;
  ResetNeeded := False;
  Rows.BeginUpdate;
  try
    if ScrollBarsNeeded then
      PanelAlign := alTop
    else
      PanelAlign := alClient;
    if Grid.Align <> PanelAlign then
    begin
      Grid.Align := PanelAlign;
      ResetNeeded := True;
    end;
    if ScrollBarsNeeded then
      Grid.Height := Min;
    if Adjust > 0 then
      BevelWidth := 2
    else
      BevelWidth := 1;
    for I := 0 to Rows.Count - 1 do
    begin
      Row := Rows[I];
      if IsGapRow[I] then
      begin
        if ScrollBarsNeeded then
        begin
          Row.SizeStyle := ssAbsolute;
          Row.Value := MinGap;
        end
        else
        begin
          Row.SizeStyle := ssPercent;
          Row.Value := Gap;
        end;
      end
      else
      begin
        Row.SizeStyle := ssAbsolute;
        Row.Value := FRowHeight + Adjust;
        Control := Grid.ControlCollection.Controls[0, I];
        if Assigned(Control) and (Control is TPtInfoPanel) then
        begin
          if TPtInfoPanel(Control).BevelWidth <> BevelWidth then
          begin
            TPtInfoPanel(Control).BevelWidth := BevelWidth;
            ResetNeeded := True;
          end
        end;
      end
    end;
  finally
    Rows.EndUpdate;
  end;
  if ResetNeeded then
    OwnerPtInfoSplitViewBase.ResetOpenState;
end;

