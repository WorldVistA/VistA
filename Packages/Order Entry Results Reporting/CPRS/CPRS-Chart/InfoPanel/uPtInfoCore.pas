function TPtInfoPresentation.GetDetailsForm: TForm;
var
  Grid: TGridPanel;
  Form: TfrmPtInfoDetails;
begin
  if PopOutType = popShowEmbedded then
    Grid := OwnerPtInfoData.OwnerPtInfoSplitViewBase.FormGrid
  else
    Grid := nil;
  if Assigned(FDialog) then
    Form := FDialog as TfrmPtInfoDetails
  else
  begin
    Form := TfrmPtInfoDetails.Create(Self, Grid);
    FDialog := Form;
  end;
  if Assigned(Grid) then
  begin
    while Grid.ControlCollection.Count > 0 do
      Grid.ControlCollection.RemoveControl(Grid.ControlCollection.Items
        [Grid.ControlCollection.Count - 1].Control);
    Grid.ControlCollection.AddControl(Form, 0, 0);
    Form.Parent := Grid;
    Form.Align := alClient;
    Form.BorderStyle := bsNone;
  end
  else
  begin
    Form.BorderStyle := bsSizeable;
    Form.Caption := DisplayText;
  end;
  Form.pnlHeader.Height := OwnerPtInfoData.RowHeight;
  Form.lblHeader.Caption := DisplayText;
  Result := Form;
end;

procedure TPtInfoPresentation.CreateHTMLForm(JSON: TJSONValue; Caption: string);
var
  Contents: TJSONArray;
  DataObj: TJSONObject;
  WebContentType: TWebContentType;
  Data: Array [wcData .. wcUISchema] of string;
begin
  if (ActionType <> actShowHTMLEditor) or (not Assigned(JSON)) then
    Exit;
  Contents := JSON.AsTypeDef<TJSONArray>('contents', nil);
  if not Assigned(Contents) then
    Exit;
  for Var I := Low(Data) to High(Data) do
    Data[I] := '';
  for var I := 0 to Contents.Count - 1 do
  begin
    WebContentType := TRttiUtils.GetEnumValueFromString<TWebContentType>
      (Contents[I].AsTypeDef<string>('contentType', ''), 'wc');
    case WebContentType of
      wcData, wcSchema, wcUISchema:
        begin
          DataObj := Contents[I].AsTypeDef<TJSONObject>('data', nil);;
          if Assigned(DataObj) then
            Data[WebContentType] := DataObj.ToString;
        end;
    end;
  end;
  if Data[wcSchema] <> '' then
  begin
    CreateHTMLDialog(TfrmHTMLDialog.TParams.Create
      (PopOutType = popShowModal, '', HTMLDialogSubmit, nil,
      HTMLDialogCloseQuery, Data[wcSchema], Data[wcUISchema], Data[wcData],
      panelId, caption));

  end;
end;

