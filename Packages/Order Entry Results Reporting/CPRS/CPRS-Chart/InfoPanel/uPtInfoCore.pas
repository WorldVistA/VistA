procedure TPtInfoPresentation.RetrieveMissingData
  (MissingData: TPtInfoDataValues);
var
  I, j: Integer;
  Value: string;
  DataValue: TPtInfoDataValue;
  Req: TPtInfoDataTypes.TRequiredType;
begin
  MissingData.Clear;
  if Assigned(RequiredData) then
  begin
    for I := 0 to RequiredData.Count - 1 do
    begin
      RequiredData[I].OptionalFound := False;
      RequiredData[I].OptionalCount := 0;
      if RequiredData[I].required and Assigned(RequiredData[I].ReturnData) then
      begin
        for j := 0 to RequiredData[I].ReturnData.Count - 1 do
        begin
          Req := RequiredData[I].ReturnData[j].RequiredType;
          if Req <> reqNo then
          begin
            Value := RetrieveValue(RequiredData[I].DataType,
              RequiredData[I].ReturnData[j].FieldType);
            case Req of
              reqOptional:
                begin
                  inc(RequiredData[I].FOptionalCount);
                  if Value <> '' then
                    RequiredData[I].OptionalFound := True;
                end;
              reqRequired:
                if Value = '' then
                begin
                  DataValue := TPtInfoDataValue.Create(RequiredData[I], Req,
                    RequiredData[I].DataType, RequiredData[I].ReturnData[j]
                    .FieldType);
                  MissingData.Add(DataValue);
                end;
            end;
          end;
        end;
      end;
    end;
    for I := 0 to RequiredData.Count - 1 do
    begin
      if (RequiredData[I].OptionalCount > 0) and
        (not RequiredData[I].OptionalFound) then
      begin
        if RequiredData[I].OptionalCount = 1 then
          Req := reqRequired
        else
          Req := reqOptional;
        if Assigned(RequiredData[I].ReturnData) then
          for j := 0 to RequiredData[I].ReturnData.Count - 1 do
          begin
            if RequiredData[I].ReturnData[j].RequiredType = reqOptional then
            begin
              Value := RetrieveValue(RequiredData[I].DataType,
                RequiredData[I].ReturnData[j].FieldType);
              if Value = '' then
              begin
                DataValue := TPtInfoDataValue.Create(RequiredData[I], Req,
                  RequiredData[I].DataType, RequiredData[I].ReturnData[j]
                  .FieldType);
                MissingData.Add(DataValue);
              end;
            end;
          end;
      end;
    end;
  end;
end;

function TPtInfoPresentation.RetrieveValue
  (ADataType: TPtInfoDataTypes.TDataType;
  AFieldType: TPtInfoDataTypes.TFieldType): string;
begin
  Result := '';
  case ADataType of
    dataDivision:
      case AFieldType of
        fldID:
          Result := Piece(RPCBrokerV.User.Division, U, 1);
        fldName:
          Result := Piece(RPCBrokerV.User.Division, U, 2);
      end;
    dataPort:
      case AFieldType of
        fldID:
          if RPCBrokerV.ListenerPort > 0 then
            Result := RPCBrokerV.ListenerPort.ToString;
      end;
    dataServer:
      case AFieldType of
        fldID:
          Result := RPCBrokerV.Server;
      end;
    dataStationNumber:
      case AFieldType of
        fldID:
          Result := copy(User.StationNumber, 1, 3);
      end;
    dataEncounterProvider:
      case AFieldType of
        fldID:
          if Encounter.Provider > 0 then
            Result := Encounter.Provider.ToString;
        fldName:
          Result := Encounter.ProviderName;
      end;
    dataUserInformation:
      case AFieldType of
        fldID:
          if User.DUZ > 0 then
            Result := User.DUZ.ToString;
        fldName:
          Result := User.Name;
      end;
    dataVisitInformation:
      case AFieldType of
        fldLocID:
          if Encounter.Location > 0 then
            Result := Encounter.Location.ToString;
        fldLocName:
          Result := Encounter.LocationName;
        fldVisitDateTime:
          if Encounter.DateTime > 0 then
            Result := Encounter.DateTime.ToString;
        fldVisitType:
          Result := Encounter.VisitCategory;
        fldVisitString:
          begin
            Result := Encounter.VisitStr;
            if Result = EMPTY_VISIT_STRING then
              Result := '';
          end;
      end;
  end;
end;

