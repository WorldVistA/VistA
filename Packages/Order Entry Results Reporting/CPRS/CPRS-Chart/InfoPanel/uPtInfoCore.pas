function TPtInfoSection.CalcImageWidth(ImageData: string): Integer;
begin
  if (ImageData = '') or (not OwnerPtInfoData.GeneralParameters.ImageIconEnabled)
  then
    Result := 0
  else if OwnerPtInfoData.IsImageIconSymbol(ImageData) then
  begin
    OwnerPtInfoData.OwnerPtInfoSplitViewBase.SymbolLabel.Font.Size :=
      MainFontSize + TPtInfoDataTypes.SymbolFontOffset;
    OwnerPtInfoData.OwnerPtInfoSplitViewBase.SymbolLabel.Symbol.FromString
      (ImageData);
    Result := OwnerPtInfoData.OwnerPtInfoSplitViewBase.SymbolLabel.SymbolSize;
  end
  else
    Result := OwnerPtInfoData.RowHeight - TPtInfoDataTypes.ImageMarginSizeTop
      [MainFont.Size] - TPtInfoDataTypes.ImageMarginSizeBottom
      [MainFont.Size] - 2;
end;

