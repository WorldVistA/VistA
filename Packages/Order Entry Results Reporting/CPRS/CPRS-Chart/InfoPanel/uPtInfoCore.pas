end;

procedure TPtInfoPanel.RealignImages;
var
  TreeOffset, SectionOffset, ImageWidth, Diff, DiffLeft, DiffRight,
    IndentOffset: Integer;
  Panel: TPanel;
  BumpDiff: Boolean;
begin
  if Assigned(FPtInfoLink.Section) and
    ((not FPtInfoLink.SectionPanel) or (FPtInfoLink.Section.ImageIcon <> ''))
  then
    ImageWidth := FPtInfoLink.Section.ImageWidth
  else
    ImageWidth := 0;
  if FPtInfoLink.SectionPanel and (not FPtInfoLink.Section.Collapsible) and
    (Alignment <> taRightJustify) then
    SectionOffset := 1
  else
    SectionOffset := 0;
  if (not FPtInfoLink.SectionPanel) and Assigned(FPtInfoLink.Section) and
    FPtInfoLink.Section.Collapsible then
  begin
    TreeOffset := FPtInfoLink.PtInfoData.OwnerPtInfoSplitViewBase.
      ImageExpand.Width;
    if (FPtInfoLink.Section.ImageIcon <> '') or (ImageWidth = 0) then
      TreeOffset := TreeOffset * 2;
  end
  else
    TreeOffset := 0;
  if (FPtInfoLink.PtInfoData.GeneralParameters.indentText) and
    (FPtInfoLink.PtInfoData.GeneralParameters.PanelTextAlignmentType <>
    taCenter) and (not FPtInfoLink.SectionPanel) and
    Assigned(FPtInfoLink.Section) and (not FPtInfoLink.Section.Collapsible) then
    IndentOffset := FPtInfoLink.PtInfoData.OwnerPtInfoSplitViewBase.
      ImageExpand.Width
  else
    IndentOffset := 0;
  if Assigned(FExpandImage) then
    case Alignment of
      taLeftJustify, taCenter:
        FExpandImage.Left := 0;
      taRightJustify:
        FExpandImage.Left := Width - FExpandImage.Width;
    end;
  if Assigned(FSymbolLabel) then
  begin
    Diff := HigherOf(ImageWidth - FSymbolLabel.Width, 0);
    DiffLeft := (Diff div 2);
    DiffRight := Diff - DiffLeft;
    if Alignment = taRightJustify then
    begin
      FSymbolLabel.Margins.Left := DiffLeft;
      FSymbolLabel.Margins.Right := TPtInfoDataTypes.LabelMarginSize +
        TreeOffset + IndentOffset + DiffRight;
      if Assigned(FExpandImage) then
        FSymbolLabel.Left := 0;
    end
    else
    begin
      FSymbolLabel.Margins.Left := TPtInfoDataTypes.LabelMarginSize + TreeOffset
        + SectionOffset + IndentOffset + DiffLeft;
      FSymbolLabel.Margins.Right := DiffRight;
      if Assigned(FExpandImage) then
        FSymbolLabel.Left := Width;
    end;
  end
  else if Assigned(FSymbolImage) then
  begin
    Panel := FSymbolImage.Parent as TPanel;
    if FPtInfoLink.SectionPanel then
      Diff := 1
    else
      Diff := 0;
    Panel.Margins.Top := TPtInfoDataTypes.ImageMarginSizeTop
      [MainFont.Size] + Diff;
    Panel.Margins.Bottom := TPtInfoDataTypes.ImageMarginSizeBottom
      [MainFont.Size] + Diff;
    if Assigned(FPtInfoLink.Section) and (not FPtInfoLink.SectionPanel) then
    begin
      Diff := FPtInfoLink.Section.CalcImageWidth(FPtInfoLink.ImageIcon);
      Diff := HigherOf(ImageWidth - Diff, 0);
    end
    else
      Diff := 0;
    DiffLeft := (Diff div 2);
    DiffRight := Diff - DiffLeft;
    if Alignment = taRightJustify then
    begin
      Panel.Margins.Left := DiffLeft;
      Panel.Margins.Right := TPtInfoDataTypes.LabelMarginSize + TreeOffset +
        IndentOffset + DiffRight;
    end
    else
    begin
      Panel.Margins.Left := TPtInfoDataTypes.LabelMarginSize + TreeOffset +
        IndentOffset + SectionOffset + DiffLeft;
      Panel.Margins.Right := DiffRight;
      if Assigned(FExpandImage) then
        Panel.Left := Panel.BoundsRect.Right;
    end;
  end
  else
  begin
    Diff := TPtInfoDataTypes.LabelMarginSize + TreeOffset + SectionOffset +
      IndentOffset;
    BumpDiff := (ImageWidth > 0);
    if BumpDiff then
    begin
      BumpDiff := (FPtInfoLink.SectionPanel and (FPtInfoLink.ImageIcon = '') and
        (not FPtInfoLink.Section.Collapsible));
      if not BumpDiff then
        BumpDiff := (not FPtInfoLink.SectionPanel) or (Alignment = taCenter);
    end;
    if BumpDiff then
      inc(Diff, TPtInfoDataTypes.LabelMarginSize + ImageWidth);
    if Alignment = taRightJustify then
      FLabel.Margins.Right := Diff
    else
      FLabel.Margins.Left := Diff;
  end;
end;

