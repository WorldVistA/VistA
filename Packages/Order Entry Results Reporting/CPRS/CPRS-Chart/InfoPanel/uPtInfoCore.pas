function TPtInfoSection.GetHasImages: Boolean;
var
  I: Integer;
begin
  if (not OwnerPtInfoData.GeneralParameters.ImageIconEnabled) then
    Result := False
  else if ImageIcon <> '' then
    Result := True
  else
  begin
    if Assigned(OwnerPtInfoData.Presentation) then
      for I := 0 to OwnerPtInfoData.Presentation.Count - 1 do
        if (OwnerPtInfoData.Presentation[I].Section.sectionId = sectionId) and
          (OwnerPtInfoData.Presentation[I].ImageIcon <> '') then
          Exit(True);
    Result := False;
  end;
end;

function TPtInfoSection.GetImageIcon: string;
begin
  if OwnerPtInfoData.GeneralParameters.ImageIconEnabled then
    Result := inherited ImageIcon
  else
    Result := '';
end;

function TPtInfoSection.GetImageWidth: Integer;
var
  I, len: Integer;

begin
  if FImageWidthCalcNeeded then
  begin
    FImageWidth := 0;
    if HasImages then
    begin
      if not Collapsible then
        FImageWidth := CalcImageWidth(ImageIcon);
      if (not Collapsible) or (not Collapsed) then
        for I := 0 to OwnerPtInfoData.Presentation.Count - 1 do
        begin
          if (OwnerPtInfoData.Presentation[I].Section.sectionId = sectionId)
          then
          begin
            len := CalcImageWidth(OwnerPtInfoData.Presentation[I].ImageIcon);
            if FImageWidth < len then
              FImageWidth := len;
          end;
        end;
    end;
    FImageWidthCalcNeeded := False;
  end;
  Result := FImageWidth;
end;

