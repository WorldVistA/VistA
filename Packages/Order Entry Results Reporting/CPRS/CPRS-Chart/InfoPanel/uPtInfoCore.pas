procedure TPtInfoPresentation.FormatForURLs(ARichEdit: TRichEdit);
var
  I, j: Integer;
  Line: string;
  Format: TCharFormat2;
begin
  I := SendMessage(ARichEdit.Handle, EM_GETEVENTMASK, 0, 0);
  SendMessage(ARichEdit.Handle, EM_SETEVENTMASK, 0, I or ENM_LINK);
  SendMessage(ARichEdit.Handle, EM_AUTOURLDETECT, Integer(True), 0);
  with ARichEdit do
  begin
    if Lines.Count > 1 then
    begin
      I := 0;
      repeat
        Line := Lines[I];
        j := Length(Line);
        if (j > 0) and (ord(Line[j]) > 32) and (Length(Lines[I + 1]) > 0) and
          (ord(Lines[I + 1][1]) > 32) then
        begin
          CaretPos := Point(j - 1, I);
          SelLength := 1;
          FillChar(Format, SizeOf(TCharFormat2), 0);
          Format.cbSize := SizeOf(TCharFormat2);
          SendGetStructMessage(Handle, EM_GETCHARFORMAT, WPARAM(True),
            Format, True);
          if (Format.dwEffects and CFE_LINK) <> 0 then
          begin
            Line := Line + Lines[I + 1];
            Lines[I] := Line;
            Lines.Delete(I + 1);
            dec(I);
          end;
        end;
        inc(I);
      until I >= (Lines.Count - 1);
    end;
    SelStart := 0;
  end;
end;

