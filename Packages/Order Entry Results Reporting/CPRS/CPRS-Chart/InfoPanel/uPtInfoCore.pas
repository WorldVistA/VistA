function TPtInfoPresentation.IsDataValid: Boolean;
var
  MissingData: TPtInfoDataValues;
  I: Integer;
  DoEncounter, DoUser, ReFloat, WasFloating: Boolean;
  dt: TPtInfoDataTypes.TDataType;
  MissingDataTypes: set of TPtInfoDataTypes.TDataType;
  Text: array [TPtInfoDataTypes.TDataType] of string;
  Line, Msg: string;
  FocusedControl: TWinControl;
begin
  Result := True;
  ReFloat := False;
  FocusedControl := Screen.ActiveControl;
  try
    if Assigned(OwnerPtInfoData) and
      Assigned(OwnerPtInfoData.OwnerPtInfoSplitViewBase) then
      WasFloating :=
        (OwnerPtInfoData.OwnerPtInfoSplitViewBase.OpenState = osFloating)
    else
      WasFloating := False;
    if (ActionType in [actShowEditor, actShowHTMLEditor]) or callDetailRPC then
    begin
      DoEncounter := False;
      DoUser := False;
      MissingDataTypes := [];
      MissingData := TPtInfoDataValues.Create;
      try
        RetrieveMissingData(MissingData);
        for I := 0 to MissingData.Count - 1 do
        begin
          if MissingData[I].DataType in [dataEncounterProvider,
            dataVisitInformation] then
            DoEncounter := True;
          if MissingData[I].DataType = dataUserInformation then
            DoUser := True;
        end;
        if DoUser then
          raise Exception.Create('Should ALWAYS have a user');
        if DoEncounter then
        begin
          UpdateEncounter(NPF_ALL);
          frmFrame.DisplayEncounterText;
          ReFloat := True;
        end;
        RetrieveMissingData(MissingData);
        if MissingData.Count > 0 then
        begin
          for I := 0 to MissingData.Count - 1 do
          begin
            include(MissingDataTypes, MissingData[I].DataType);
            Text[MissingData[I].DataType] := MissingData[I]
              .OwnerPtInfoRequiredData.ErrorMessage;
          end;
          Msg := '';
          for dt := Low(TPtInfoDataTypes.TDataType)
            to High(TPtInfoDataTypes.TDataType) do
            if dt in MissingDataTypes then
            begin
              Line := Text[dt];
              if Line = '' then
                Line := copy(GetEnumName(TypeInfo(TPtInfoDataTypes.TDataType),
                  ord(dt)), 5, MaxInt) + ' not defined';
              if not Line.EndsWith('.') then
                Line := Line + '.';
              if Msg <> '' then
                Msg := Msg + CRLF;
              Msg := Msg + Line;
            end;
          if Msg <> '' then
            ShowMessage(Msg);
          Result := False;
        end;
      finally
        FreeAndNil(MissingData);
      end;
    end;
    if Assigned(OwnerPtInfoData) and
      Assigned(OwnerPtInfoData.OwnerPtInfoSplitViewBase) and ReFloat and WasFloating
    then
      OwnerPtInfoData.OwnerPtInfoSplitViewBase.OpenState := osFloating;
  finally
    if ShouldFocus(FocusedControl) then
      FocusedControl.SetFocus;
  end;
end;

