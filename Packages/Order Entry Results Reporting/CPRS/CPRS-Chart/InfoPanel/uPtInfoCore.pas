{ TPtInfoLink }

constructor TPtInfoLink.Create(AControl: TWinControl; ASection: TPtInfoSection;
  APresentation: TPtInfoPresentation; AGridPanel: TGridPanel);
begin
  inherited Create;
  FControl := AControl;
  FSection := ASection;
  FPresentation := APresentation;
  FGridPanel := AGridPanel;
  FSectionPanel := Assigned(FSection);
  if (not Assigned(FSection)) and Assigned(FPresentation) and
    Assigned(FPresentation.Section) then
    FSection := FPresentation.Section;
  if Assigned(FSection) then
    FPtInfoData := FSection.OwnerPtInfoData
  else if Assigned(FPresentation) then
    FPtInfoData := FPresentation.OwnerPtInfoData;
end;

destructor TPtInfoLink.Destroy;
begin
  OrphanControl;
  inherited;
end;

function TPtInfoLink.GetImageIcon: string;
begin
  Result := '';
  if SectionPanel then
  begin
    if Assigned(Section) then
      Result := Section.ImageIcon;
  end
  else if Assigned(Presentation) then
    Result := Presentation.ImageIcon;
end;

function TPtInfoLink.GetSection: TPtInfoSection;
begin
  if (not Assigned(FSection)) and Assigned(FPresentation) and
    Assigned(FPresentation.Section) then
    FSection := FPresentation.Section;
  Result := FSection;
end;

function TPtInfoLink.LinkScreenReaderText(hasExpandImage: boolean): string;
begin
  result := 'Unknown Information Panel';
  if SectionPanel then
  begin
    if hasExpandImage then
    begin
      if Section.FCollapsed then result := 'press spacebar to expand section'
      else result := 'press spacebar to collapse section';
    end
    else result := 'Section Header';
  end;
  if Assigned(Presentation) then
  begin
    if Presentation.GetActionType = actNone then result := 'Information Only'
    else if (Presentation.GetActionType = actShowDetail) or
            (Presentation.GetActionType = actShowMessage) then
      result := ' press space bar to view additional information'
    else if (Presentation.GetActionType = actShowEditor) or
            (Presentation.GetActionType = actShowHTMLEditor) then
      result := ' press space bar to update record'
    else if Presentation.GetActionType = actShowURL then result := 'press space to view more information in a broswer';
  end;
end;

procedure TPtInfoLink.OrphanControl;
begin
  FControl.Visible := False;
  FControl.Align := alNone;
  FControl.Parent := nil;
  if Assigned(FGridPanel) then
    FGridPanel.ControlCollection.RemoveControl(FControl);
end;

{ TPtInfoPanel }

type
  TBitmapAccess = class(Vcl.Graphics.TBitmap);

constructor TPtInfoPanel.Create(ASection: TPtInfoSection;
  APresentation: TPtInfoPresentation; AGridPanel: TGridPanel);
const
  InvaldImageError = '59961;clWindowText;60304;clRed';

var
  ImageData: string;

  procedure CreateLabel;
  begin
    FLabel := TLabel.Create(Self);
    FLabel.Parent := Self;
    FLabel.Align := alClient;
    FLabel.AlignWithMargins := True;
    FLabel.Margins.Top := 0;
    FLabel.Margins.Bottom := 0;
    FLabel.Margins.Left := TPtInfoDataTypes.LabelMarginSize;
    FLabel.Margins.Right := TPtInfoDataTypes.LabelMarginSize;
    FLabel.Alignment := Alignment;
    FLabel.Layout := tlCenter;
  end;

  procedure CreateExpandImage;
  begin
    if Assigned(ASection) and ASection.Collapsible then
    begin
      FExpandImage := TImage.Create(Self);
      FExpandImage.Parent := Self;
      if Alignment = taRightJustify then
      begin
        FExpandImage.Align := alRight;
        FExpandImage.Margins.Left := 0;
        FExpandImage.Margins.Right := TPtInfoDataTypes.LabelMarginSize;
      end
      else
      begin
        FExpandImage.Align := alLeft;
        FExpandImage.Margins.Left := TPtInfoDataTypes.LabelMarginSize;
        FExpandImage.Margins.Right := 0;
      end;
      FExpandImage.AlignWithMargins := True;
      FExpandImage.Margins.Top := 0;
      FExpandImage.Margins.Bottom := 0;
      FExpandImage.Center := True;
      FExpandImage.Transparent := True;
      if ASection.Collapsed then
        FExpandImage.Picture.Assign
          (FPtInfoLink.PtInfoData.OwnerPtInfoSplitViewBase.ImageExpand.Picture)
      else
        FExpandImage.Picture.Assign
          (FPtInfoLink.PtInfoData.OwnerPtInfoSplitViewBase.
          ImageCollapse.Picture);
      FExpandImage.Width := FPtInfoLink.PtInfoData.OwnerPtInfoSplitViewBase.
        ImageExpand.Width;
    end;
  end;

  procedure CreateSymbolLabel;
  begin
    FSymbolLabel := TORSymbolLabel.Create(Self);
    FSymbolLabel.Parent := Self;
    FSymbolLabel.AlignWithMargins := True;
    FSymbolLabel.Margins.Top := 0;
    FSymbolLabel.Margins.Bottom := 0;
    if Alignment = taRightJustify then
      FSymbolLabel.Align := alRight
    else
      FSymbolLabel.Align := alLeft;
    FSymbolLabel.Alignment := taCenter;
    FSymbolLabel.Layout := tlCenter;
    FSymbolLabel.Symbol.FromString(ImageData);
  end;

  procedure CreateImageIcon;
  var
    Panel: TPanel;
    Mem: TMemoryStream;

    function ReadBool: Boolean;
    begin
      Mem.Read(Result, SizeOf(Boolean));
    end;

  begin
    Panel := TPanel.Create(Self);
    Panel.Parent := Self;
    Panel.BevelOuter := bvNone;
    Panel.Caption := '';
    Panel.AlignWithMargins := True;
    if Alignment = taRightJustify then
      Panel.Align := alRight
    else
      Panel.Align := alLeft;
    Panel.Width := Panel.Height;
    Panel.OnResize := PanelResize;
    FSymbolImage := TImage.Create(Self);
    FSymbolImage.Parent := Panel;
    FSymbolImage.Align := alClient;
    Mem := TMemoryStream.Create;
    try
      try
        Mem.Size := Length(ImageData) div 2;
        HexToBin(PWideChar(ImageData), Mem.Memory^, Mem.Size);
        Mem.Position := 0;
        FSymbolImage.Center := ReadBool;
        FSymbolImage.Stretch := ReadBool;
        FSymbolImage.Transparent := ReadBool;
        TBitmapAccess(FSymbolImage.Picture.Bitmap).ReadData(Mem);
      except
        FreeAndNil(FSymbolImage);
        FreeAndNil(Panel);
        ImageData := InvaldImageError;
        if FPtInfoLink.SectionPanel then
          FPtInfoLink.Section.ImageIcon := ImageData
        else
          FPtInfoLink.Presentation.ImageIcon := ImageData;
        CreateSymbolLabel;
      end;
    finally
      Mem.Free;
    end;
  end;

begin
  if (not Assigned(ASection)) and (not Assigned(APresentation)) then
    raise EArgumentException.Create
      ('Can''t create TPtInfoPanel without a valid TPtInfoSection or TPtInfoPresentation.');
  inherited Create(nil);
  FPtInfoLink := TPtInfoLink.Create(Self, ASection, APresentation, AGridPanel);
  Font.Assign(MainFont);
  ParentBackground := False;
  ParentColor := False;
  Caption := '';
  if (not FPtInfoLink.PtInfoData.GeneralParameters.ImageIconEnabled) then
    ImageData := ''
  else
    ImageData := FPtInfoLink.ImageIcon;
  Alignment := FPtInfoLink.PtInfoData.GeneralParameters.PanelTextAlignmentType;
  CreateLabel;
  CreateExpandImage;
  if (ImageData <> '') then
  begin
    if TPtInfoData.IsImageIconSymbol(ImageData) then
      CreateSymbolLabel
    else
      CreateImageIcon;
  end;
//  if ScreenReaderActive then
//  begin
////    (GetParentForm(AGridPanel) as TfrmBase508Form).amgrMain.AccessText[TWinControl(self)] := self.LongText + ' Click to perform action';
//    (GetParentForm(AGridPanel) as TfrmBase508Form).amgrMain.AccessText[self] := self.FLabel.ToString + ' Click to perform action';
//  end;
end;

destructor TPtInfoPanel.Destroy;
begin
  if assigned(FLabel) then FreeAndNil(FLabel);
  if assigned(FExpandImage) then FreeAndNil(FExpandImage);
  if assigned(FSymbolImage) then FreeAndNil(FSymbolImage);

  FreeAndNil(FPtInfoLink);
  inherited;
end;

