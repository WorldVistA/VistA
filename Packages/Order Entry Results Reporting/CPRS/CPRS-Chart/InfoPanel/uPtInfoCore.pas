function TPtInfoPresentation.DataToJSON: TJSONObject;
var
  Elem, DType, Data: TJSONObject;
  List: TJSONArray;
  Value: string;

begin
  Result := nil;
  if not IsDataValid then
    Exit;
  Result := TJSONObject.Create;
  Result.AddPair('id', panelId);
  if Assigned(Section) and Assigned(Section) then
    Result.AddPair('isNational', Section.IsNational);
  Result.AddPair('patientId', Patient.DFN);
  Result.AddPair('package', VISTA_PACKAGE);
  Result.AddPair('connectionUser', User.DUZ);
  if Assigned(RequiredData) and (RequiredData.Count > 0) then
  begin
    List := TJSONArray.Create;
    Result.AddPair('requiredData', List);
    for var I := 0 to RequiredData.Count - 1 do
    begin
      Elem := TJSONObject.Create;
      List.Add(Elem);
      DType := TJSONObject.Create;
      Elem.AddPair('dataType', DType);
      DType.AddPair('name', RequiredData[I].dataName);
      Data := TJSONObject.Create;
      DType.AddPair('data', Data);
      if Assigned(RequiredData[I].ReturnData) and
        (RequiredData[I].ReturnData.Count > 0) then
        for var j := 0 to RequiredData[I].ReturnData.Count - 1 do
        begin
          Value := RetrieveValue(RequiredData[I].DataType,
            RequiredData[I].ReturnData[j].FieldType);
          Data.AddPair(RequiredData[I].ReturnData[j].dataName, Value);
        end;
    end;
  end;
end;

