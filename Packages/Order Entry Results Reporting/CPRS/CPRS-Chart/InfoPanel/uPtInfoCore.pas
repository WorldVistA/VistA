function TPtInfoData.SetupPanels(PageID, ARowHeight: Integer): Boolean;
var
  I, j, GapCount: Integer;
  HasNational, HasLocal, NeedGap: Boolean;
  Gap: Double;

  procedure AddGap;
  var
    Row: TRowItem;
  begin
    if NeedGap then
    begin
      Row := Self.OwnerPtInfoSplitViewBase.PanelGrid.RowCollection.Add;
      Row.SizeStyle := ssPercent;
      Row.Value := Gap;
    end;
  end;

begin
  Result := False;
  FRowHeight := ARowHeight;
  OwnerPtInfoSplitViewBase.PanelGrid.BeginUpdate;
  try
    for I := 0 to Presentation.Count - 1 do
      Presentation[I].OrphanPanels;
    for I := 0 to Sections.Count - 1 do
    begin
      Sections[I].OrphanPanels;
      Sections[I].Used := False;
    end;
    OwnerPtInfoSplitViewBase.PanelGrid.ControlCollection.Clear;
    OwnerPtInfoSplitViewBase.PanelGrid.RowCollection.Clear;
    for I := 0 to Presentation.Count - 1 do
      if Presentation[I].ShouldDisplayPanel(PageID) and
        Assigned(Presentation[I].Section) then
        Presentation[I].Section.Used := True;
    GapCount := 0;
    HasNational := False;
    HasLocal := False;
    for I := 0 to Sections.Count - 1 do
      if Sections[I].Used then
      begin
        if Sections[I].IsNational then
          HasNational := True
        else
          HasLocal := True;
        inc(GapCount);
      end;
    if HasNational and HasLocal then
      dec(GapCount);
    if GapCount <= 0 then
      Exit;
    Gap := 100.0 / GapCount;
    NeedGap := not HasNational;
    for var National := True downto False do
    begin
      for I := 0 to Sections.Count - 1 do
        if Sections[I].Used and (Sections[I].IsNational = National) then
        begin
          AddGap;
          NeedGap := True;
          Sections[I].SetupSection(ARowHeight);
          for j := 0 to Presentation.Count - 1 do
            if Presentation[j].ShouldDisplayPanel(PageID) and
              (Presentation[j].Section = Sections[I]) then
            begin
              Presentation[j].SetupPanels(ARowHeight);
              Result := True;
            end;
        end;
    end;
    if HasLocal then
      NeedGap := False;
    AddGap;
  finally
    OwnerPtInfoSplitViewBase.PanelGrid.EndUpdate;
  end;
  ResetFont(ARowHeight);
  AdjustPanels;
  ResetPanelText(OwnerPtInfoSplitViewBase.OpenState <> osUnpinned);
end;

