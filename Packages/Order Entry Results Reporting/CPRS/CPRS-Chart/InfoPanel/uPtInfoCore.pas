procedure TPtInfoPresentation.HTMLDialogCloseQuery(Sender: TfrmHTMLDialog;
  Content: TJSONObject; Canceling: Boolean; var CanClose: Boolean);
var
  JSONResults: TJSONValue;
  Results: TPtInfoSaveResults;
  Error: string;
begin
  if Canceling then
  begin
    resetFocus;
    Exit;
  end;
  JSONResults := CreateJSONfromHTMLEditorSave(Content, Error);
  try
    if Error <> '' then
    begin
      ShowMessage(Error);
      CanClose := False;
      exit;
    end
    else if Assigned(JSONResults) then
        begin
          Results := TPtInfoDataConverter.ToObject<TPtInfoSaveResults>
            (JSONResults.ToString);
          try
            if Assigned(OwnerPtInfoData.OwnerPtInfoSplitViewBase) and
              Results.RefreshAllInfoPanels then
              OwnerPtInfoData.OwnerPtInfoSplitViewBase.Reload;
            if Assigned(Results.NoteInformation) and
              (Results.NoteInformation.ID > 0) then
            begin
              Changes.Add(CH_DOC, Results.NoteInformation.ID.ToString,
                Results.NoteInformation.Details, '', CH_SIGN_YES);
              PostMessage(Application.MainForm.Handle, UM_NEWNOTE, 0, 0);
            end;
          finally
            FreeAndNil(Results);
          end;
          resetFocus;
        end
        else
          exit;
  finally
//    FreeAndNil(JSONResults);
  end;
end;

