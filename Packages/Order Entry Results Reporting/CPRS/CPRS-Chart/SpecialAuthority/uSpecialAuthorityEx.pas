procedure FreeAndNilOld(ATypeInf: PTypeInfo; Instance: TObject;
  FieldName: string);
var
  LField: TRttiField;
begin
  LField := TRttiUtils.GetRttiField(ATypeInf, FieldName);
  if Assigned(LField) then
  begin
    LField.GetValue(Instance).AsObject.Free;
    LField.SetValue(Instance, nil);
  end;
end;

{ TSpecialAuthorityCheckBox }

procedure TSpecialAuthorityCheckBox.Click;
begin
  if not FInternalClick then
  begin
    FInternalClick := True;
    try
      if FCheckBoxType = cbtBoth then
      begin
        case State of
          cbUnchecked:
            FSpecialAuthorityEx.Value := savNo;
          cbChecked:
            FSpecialAuthorityEx.Value := savYes;
          cbGrayed:
            FSpecialAuthorityEx.Value := savUnanswered;
        end;
      end
      else if Checked then
      begin
        if Assigned(FLinkedCheckBox) then
          FLinkedCheckBox.Checked := False;
        FSpecialAuthorityEx.Value := FSpecialAuthorityValue;
      end
      else if (not Assigned(FLinkedCheckBox)) or (not FLinkedCheckBox.Checked)
      then
        FSpecialAuthorityEx.Value := savUnanswered;
      SpecialAuthorityEx.OwnerSpecialAuthoritiesEx.ApplyValueChangeActions;
    finally
      FInternalClick := False;
    end;
  end;
  inherited;
end;

type
  TCustomHintAccess = class(TCustomHint);

procedure TSpecialAuthorityCheckBox.CMDialogChar(var Message: TCMDialogChar);
begin
  if (FCheckBoxType <> cbtBoth) and IsAccel(Message.CharCode, Caption) then
  begin
    Message.Result := 1;
    if Assigned(CustomHint) then
      TCustomHintAccess(CustomHint).ShowHint(Self);
  end
  else
    inherited;
end;

constructor TSpecialAuthorityCheckBox.Create(AOwner: TComponent;
  ASpecialAuthority: TSpecialAuthorityEx; ACheckBoxType: TCheckBoxType;
  ACustomHint: TCustomHint; ALinkedCheckBox: TSpecialAuthorityCheckBox);
begin
  inherited Create(AOwner);
  if not Assigned(ASpecialAuthority) then
    raise EArgumentException.Create
      ('ASpecialAuthority argument required in TSpecialAuthorityCheckBox.Create');
  FSpecialAuthorityEx := ASpecialAuthority;
  FCheckBoxType := ACheckBoxType;
  Flat := True;
  case FCheckBoxType of
    cbtYes:
      begin
        FSpecialAuthorityValue := savYes;
        if Assigned(FSpecialAuthorityEx.FCheckBoxYes) then
          FreeAndNil(FSpecialAuthorityEx.FCheckBoxYes);
        FSpecialAuthorityEx.FCheckBoxYes := Self;
        Caption := '';
        Hint := FSpecialAuthorityEx.FSpecialAuthorityTypeEx.Description;
      end;
    cbtNo:
      begin
        FSpecialAuthorityValue := savNo;
        if Assigned(FSpecialAuthorityEx.FCheckBoxNo) then
          FreeAndNil(FSpecialAuthorityEx.FCheckBoxNo);
        FSpecialAuthorityEx.FCheckBoxNo := Self;
        Caption := ' ' + FSpecialAuthorityEx.SpecialAuthorityTypeEx.DisplayName;
        Hint := FSpecialAuthorityEx.FSpecialAuthorityTypeEx.Description;
      end;
    cbtBoth:
      begin
        AllowGrayed := True;
        if Assigned(FSpecialAuthorityEx.FCheckBoxBoth) then
          FreeAndNil(FSpecialAuthorityEx.FCheckBoxBoth);
        FSpecialAuthorityEx.FCheckBoxBoth := Self;
        Caption := '';
        Hint := FSpecialAuthorityEx.FSpecialAuthorityTypeEx.DisplayText
      end;
  end;
  if Assigned(ALinkedCheckBox) then
  begin
    FLinkedCheckBox := ALinkedCheckBox;
    ALinkedCheckBox.FLinkedCheckBox := Self;
  end;
  FInternalClick := True;
  try
    if (FCheckBoxType = cbtBoth) then
    begin
      FSpecialAuthorityEx.Value := FSpecialAuthorityEx.DefaultValue;
      if FSpecialAuthorityEx.Value = savUnanswered then
        FSpecialAuthorityEx.Value := FSpecialAuthorityEx.SpecialAuthorityTypeEx.
          DefaultValue;
      case FSpecialAuthorityEx.Value of
        savUnanswered:
          State := cbGrayed;
        savNo:
          State := cbUnchecked;
        savYes:
          State := cbChecked;
      end;
    end
    else if FSpecialAuthorityEx.Value = FSpecialAuthorityValue then
      Checked := True;
  finally
    FInternalClick := False;
  end;
  Enabled := FSpecialAuthorityEx.Enabled;
  ShowHint := True;
  if Assigned(ACustomHint) then
  begin
    CustomHint := ACustomHint;
    ParentCustomHint := True;
    Hint := '|' + Hint;
  end;
end;

destructor TSpecialAuthorityCheckBox.Destroy;
begin
  if Assigned(FSpecialAuthorityEx) then
  begin
    if FCheckBoxType = cbtBoth then
      FSpecialAuthorityEx.FCheckBoxBoth := nil
    else if FSpecialAuthorityValue = savYes then
      FSpecialAuthorityEx.FCheckBoxYes := nil
    else
      FSpecialAuthorityEx.FCheckBoxNo := nil;
  end;
  if Assigned(FLinkedCheckBox) then
    FLinkedCheckBox.FLinkedCheckBox := nil;
  inherited;
end;

