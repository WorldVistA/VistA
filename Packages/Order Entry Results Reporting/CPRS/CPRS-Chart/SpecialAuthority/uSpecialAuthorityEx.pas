begin
  FreeAndNil(FSpecialAuthorityEx);
  inherited;
end;

function TSpecialAuthoritiesEx.GetBoldText(ACode: string;
ASpecialAuthoritiesEx: TSpecialAuthoritiesEx): Boolean;
begin
  Result := (Item[ACode].Yes and (not ASpecialAuthoritiesEx[ACode].Yes));
end;

function TSpecialAuthoritiesEx.GetCount: Integer;
begin
  Result := SpecialAuthority.Count;
end;

function TSpecialAuthoritiesEx.GetHasUnanswered: Boolean;
begin
  ApplyValueChangeActions;
  for var I := 0 to SpecialAuthority.Count - 1 do
    if SpecialAuthority[I].Visible and SpecialAuthority[I].Enabled and
      (SpecialAuthority[I].Value = savUnanswered) then
      Exit(True);
  Result := False;
end;

function TSpecialAuthoritiesEx.GetItem(Index: Integer): TSpecialAuthorityEx;
begin
  Result := SpecialAuthority[Index];
end;

function TSpecialAuthoritiesEx.GetItem(ACode: string): TSpecialAuthorityEx;
begin
  for var I := 0 to SpecialAuthority.Count - 1 do
    if SpecialAuthority[I].Code = ACode then
      Exit(SpecialAuthority[I]);
  if Assigned(SpecialAuthorityTypesEx[ACode]) then
  begin
    Result := FNewSpecialAuthorityClass.Create;
    Result.PopulateOwner(Self);
    Result.Code := ACode;
    Result.FValue := savUnanswered;
    Result.Visible := False;
    SpecialAuthority.Add(Result);
    SpecialAuthority.Sort;
    Exit;
  end;
  Result := nil;
end;

function TSpecialAuthoritiesEx.GetVisitStringText: string;
begin
  Result := '';
  for var I := 0 to SpecialAuthority.Count - 1 do
    if SpecialAuthority[I].Yes then
    begin
      if Result <> '' then
        Result := Result + ', ';
      Result := Result + SpecialAuthority[I].SpecialAuthorityTypeEx.DisplayText;
    end;
  if Result <> '' then
    Result := RelatedTo + Result;
end;

procedure TSpecialAuthoritiesEx.PopulateOwner;
begin
  for var I := 0 to FSpecialAuthorityEx.Count - 1 do
    FSpecialAuthorityEx[I].PopulateOwner(Self);
end;

procedure TSpecialAuthoritiesEx.ReloadSpecialAuthorityTypes;
var
i: integer;
Reload: boolean;
Error: string;
begin
  reload := false;
  if SpecialAuthority.Count <> SpecialAuthorityTypesEx.Count  then
    Reload := true
  else begin
    for i := 0 to SpecialAuthority.Count - 1 do
    begin
      if SpecialAuthorityTypesEx.Item[SpecialAuthority[i].Code] = nil then
      begin
        Reload := true;
        break;
      end
      else begin
        if (SpecialAuthorityTypesEx.Item[SpecialAuthority[i].Code].disabled) and
        (SpecialAuthority[i].isVisible) then
        begin
          Reload := true;
          break;
        end;
      end;
    end;
  end;
  if Reload then
  begin
    ReloadSpecialAuthorityTypesEx(Error);
    if Error = '' then FReloading := true;
  end;
end;

procedure TSpecialAuthoritiesEx.ResetEnabled;
begin
  for var I := 0 to Count - 1 do
    Item[I].Enabled := Item[I].FDesiredEnabled;
  ApplyValueChangeActions;
end;

