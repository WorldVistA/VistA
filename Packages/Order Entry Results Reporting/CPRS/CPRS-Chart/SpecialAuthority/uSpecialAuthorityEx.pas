  Result := Assigned(FSpecialAuthorityTypeEx);
end;

function TSpecialAuthorityEx.GetVisible: Boolean;
begin
  if Valid then
  begin
    Result := inherited Visible;
    if Result and (FOwnerSpecialAuthoritiesEx.FPackageLink <> '') then
      for var I := 0 to FSpecialAuthorityTypeEx.package.Count - 1 do
        if FOwnerSpecialAuthoritiesEx.FPackageLink = FSpecialAuthorityTypeEx.
          package[I].name then
        begin
          Result := not FSpecialAuthorityTypeEx.package[I].excluded;
          break;
        end;
  end
  else
    Result := False;
end;

function TSpecialAuthorityEx.GetVisibleProperty: boolean;
begin
  result := inherited Visible;
end;

function TSpecialAuthorityEx.GetYes: Boolean;
begin
  Result := Visible and Enabled and (Value = savYes);
end;

procedure TSpecialAuthorityEx.PopulateOwner(AOwner: TSpecialAuthoritiesEx);
begin
  FOwnerSpecialAuthoritiesEx := AOwner;
end;

procedure TSpecialAuthorityEx.SetCode(const Value: string);
begin
  if inherited Code <> Value then
  begin
    inherited Code := Value;
    FSpecialAuthorityTypeEx := SpecialAuthorityTypesEx[Value];
  end;
end;

procedure TSpecialAuthorityEx.SetEnabled(const Value: Boolean);
begin
  FDesiredEnabled := Value;
  if (not Value) or ((FEnabled <> Value) and
    Assigned(FOwnerSpecialAuthoritiesEx) and
    FOwnerSpecialAuthoritiesEx.CanEnable) then
  begin
    FEnabled := Value;
    if Assigned(FCheckBoxYes) then
      FCheckBoxYes.Enabled := Value;
    if Assigned(FCheckBoxNo) then
      FCheckBoxNo.Enabled := Value;
    if Assigned(FCheckBoxBoth) then
      FCheckBoxBoth.Enabled := Value;
  end;
end;

procedure TSpecialAuthorityEx.SetStringValue(const AValue: string);
begin
  for var v := Low(TSpecialAuthorityValue) to High(TSpecialAuthorityValue) do
    if AValue = SpecialAuthorityValueStrings[v] then
    begin
      Value := v;
      Exit;
    end;
  Value := savUnanswered;
end;

procedure TSpecialAuthorityEx.SetValue(const AValue: TSpecialAuthorityValue);
begin
  if FValue <> AValue then
  begin
    if Valid then
      FValue := AValue
    else
      FValue := savUnanswered;
    FOwnerSpecialAuthoritiesEx.FChanged := True;
    if Assigned(FCheckBoxBoth) then
    begin
      case AValue of
        savUnanswered:
          FCheckBoxBoth.State := cbGrayed;
        savNo:
          FCheckBoxBoth.State := cbUnchecked;
        savYes:
          FCheckBoxBoth.State := cbChecked;
      end;
    end
    else if Assigned(FCheckBoxYes) and Assigned(FCheckBoxNo) then
      case FValue of
        savUnanswered:
          begin
            FCheckBoxYes.Checked := False;
            FCheckBoxNo.Checked := False;
          end;
        savNo:
          FCheckBoxNo.Checked := True;
        savYes:
          FCheckBoxYes.Checked := True;
      end;
  end;
end;

procedure TSpecialAuthorityEx.SetVisible(const Value: Boolean);
begin
  if inherited Visible <> Value then
  begin
    inherited Visible := Value;
    Enabled := Value;
  end;
end;

