procedure TSpecialAuthoritiesEx.ApplyDefaults;
begin
  for var I := 0 to SpecialAuthority.Count - 1 do
    if SpecialAuthority[I].Valid and (SpecialAuthority[I].Value = savUnanswered)
    then
      SpecialAuthority[I].Value := SpecialAuthority[I]
        .SpecialAuthorityTypeEx.DefaultValue;
end;

procedure TSpecialAuthoritiesEx.ApplyValueChangeActions;
var
  Actions: TObjectList<TValueChangeActionEx>;
begin
  if FApplyingValueChangeActions then
    Exit;
  FApplyingValueChangeActions := True;
  try
    for var I := 0 to SpecialAuthority.Count - 1 do
    begin
      if not SpecialAuthority[I].Valid then
        continue;
      Actions := SpecialAuthority[I].SpecialAuthorityTypeEx.ValueChangeActions;
      for var j := 0 to Actions.Count - 1 do
        if SpecialAuthority[I].Value = Actions[j].RelatedValue then
          for var saa := Low(TSpecialAuthorityAction)
            to High(TSpecialAuthorityAction) do
            if saa in Actions[j].RelatedActions then
              for var k := 0 to Actions[j].linkedSpecialAuthorities.Count - 1 do
                case saa of
                  saaSetNo:
                    Item[Actions[j].linkedSpecialAuthorities[k]].Value := savNo;
                  saaSetYes:
                    Item[Actions[j].linkedSpecialAuthorities[k]].Value
                      := savYes;
                  saaSetUnanswered:
                    Item[Actions[j].linkedSpecialAuthorities[k]].Value :=
                      savUnanswered;
                  saaDisable:
                    Item[Actions[j].linkedSpecialAuthorities[k]]
                      .Enabled := False;
                  saaEnable:
                    Item[Actions[j].linkedSpecialAuthorities[k]]
                      .Enabled := True;
                end;
    end;
  finally
    FApplyingValueChangeActions := False;
  end;
end;

function TSpecialAuthoritiesEx.CanEnable: Boolean;
begin
  if Assigned(FOnCanEnableEvent) then
    Result := FOnCanEnableEvent(Self)
  else
    Result := True;
end;

procedure TSpecialAuthoritiesEx.ChangeEnabled(AEnabled: Boolean);
begin
  for var I := 0 to SpecialAuthority.Count - 1 do
    SpecialAuthority[I].Enabled := AEnabled;
end;

procedure TSpecialAuthoritiesEx.Clear(ClearVisible: Boolean);
begin
  for var I := 0 to SpecialAuthority.Count - 1 do
  begin
    SpecialAuthority[I].FValue := savUnanswered;
    if ClearVisible then
    begin
      SpecialAuthority[I].Visible := False;
      SpecialAuthority[I].Enabled := False;
      SpecialAuthority[I].default := '';
    end;
  end;
  FChanged := False;
end;

procedure TSpecialAuthoritiesEx.CopyFrom(Source: TSpecialAuthoritiesEx;
  ACopyTypes: TCopyTypes);
var
  sa1, sa2: TSpecialAuthorityEx;
begin
  if Assigned(Source) then
  begin
    for var I := 0 to Source.Count - 1 do
    begin
      sa1 := Source[I];
      sa2 := Item[sa1.Code];
      if ctCopyVisible in ACopyTypes then
      begin
        sa2.default := sa1.default;
        sa2.Visible := sa1.Visible;
        sa2.Enabled := sa1.Enabled;
      end;
      if ctCopyValues in ACopyTypes then
        sa2.FValue := sa1.FValue;
    end;
    if ctCopyChanged in ACopyTypes then
      FChanged := Source.FChanged
    else if ctClearChanged in ACopyTypes then
      FChanged := False;
  end;
end;

constructor TSpecialAuthoritiesEx.Create(ANewSpecialAuthorityClass
  : TSpecialAuthorityClass);
begin
  Create;
  FNewSpecialAuthorityClass := ANewSpecialAuthorityClass;
end;

constructor TSpecialAuthoritiesEx.Create;
begin
  inherited Create;
  FreeAndNilOld(TypeInfo(TObjectList<TSpecialAuthority>), Self,
    'FSpecialAuthority');
  FSpecialAuthorityEx := TObjectList<TSpecialAuthorityEx>.Create
    (TComparer<TSpecialAuthorityEx>.Construct(
    function(const Left, Right: TSpecialAuthorityEx): Integer
    begin
      if Left.Valid and Right.Valid then
        if Left.SpecialAuthorityTypeEx.Sequence < Right.SpecialAuthorityTypeEx.Sequence
        then
          Result := -1
        else
          Result := 1
      else
        Result := 0;
    end), True);
  FNewSpecialAuthorityClass := TSpecialAuthorityEx;
  FReloading := false;
end;

